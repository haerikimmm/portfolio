<section class="hero">
	<div class="container">
		<div class="hero-content reveal">
			<div class="hero-grid">
				
				<!-- LEFT: Intro -->
				<div class="hero-tagline">
					<h1><span class="typewriter"></span></h1>
					<p class="intro-sub">Studying Human-Computer Interaction (HCI) in Make Lab, KAIST. Previously a product designer and UX researcher @MegazoneCloud.</p>
				</div>

				<!-- RIGHT: Image -->
				<div class="hero-image">
					<img src="/portfolio/images/sketch.png" alt="Illustration of designer at work" />
					<span class="hover-hi">hi!</span>
				</div>

			</div>
		</div>
	</div>
</section>


<script>
	const text = "I enjoy crafting things by hand and experimenting with interactions between the physical and digital world.";
	const speed = 50;
	
	const h1 = document.querySelector('.typewriter');
	let i = 0;
	
	function typeWriter() {
		if (i < text.length && h1) {
			h1.textContent += text.charAt(i);
			i++;
			setTimeout(typeWriter, speed);
		}
	}
	
	// Start typing when page loads
	typeWriter();
</script>



