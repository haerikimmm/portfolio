	@media (max-width: 768px) {
		.nav-container {
			border-radius: 0;
			border: none;
			padding-left: 0;
			padding-right: 0;
		}

		.menu-icon {
			display: flex;
		}

		.links {
			display: flex;
			position: fixed;
			top: 0;
			right: 0;
			height: 100vh;
			width: 100%;
			background: var(--color-bg);
			flex-direction: column;
