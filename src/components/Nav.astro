	.nav-link:hover {
		color: #555555;
	}

	/* Mobile Toggle */
	.menu-toggle {
		display: none;
	}
	
	.menu-icon {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 6px;
		width: 24px;
