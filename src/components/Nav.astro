			gap: 3rem;
			transform: translateX(100%);
			transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
			visibility: hidden;
			opacity: 0;
		}

		.menu-toggle:checked ~ .links {
			transform: translateX(0);
